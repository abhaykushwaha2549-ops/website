# ──────────────────────────────────────────────────────────
# Lightinmotion Server — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────

# Admin password for the dashboard
ADMIN_PASSWORD=lightinmotion@admin

# Port (Render sets this automatically — leave blank locally)
# PORT=3001

# ── Supabase (required for production on Render) ──────────
# Leave blank to use local disk storage (development only)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-project.vercel.app
