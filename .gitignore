# Root .gitignore for the Lightinmotion monorepo

# ── Node / npm ──────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment files (never commit secrets) ────────────────────────────────
.env
.env.local
.env.production
server/.env

# ── Build output ─────────────────────────────────────────────────────────────
app/dist/

# ── Server: local storage (dev only, not needed in git) ──────────────────────
server/uploads/
server/db.json

# ── OS & editor files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
